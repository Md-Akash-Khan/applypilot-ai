# App
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ApplyPilot AI"
NEXT_PUBLIC_REPOSITORY_URL="https://github.com/Md-Akash-Khan/applypilot-ai"
APP_SESSION_SECRET="replace-this-with-a-long-random-secret"
# NEXTAUTH_SECRET is also supported for compatibility.
NEXTAUTH_SECRET=""

# Default owner account created by `npm run db:seed`
APP_SINGLE_USER_EMAIL="owner@applypilot.local"
APP_SINGLE_USER_PASSWORD="change-this-before-production"
APP_SINGLE_USER_NAME="ApplyPilot Owner"

# PostgreSQL / Neon
DATABASE_URL="postgresql://applypilot:applypilot@localhost:5432/applypilot?schema=public"

# AI parser is optional. The deterministic parser works without a key.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.6-luna"

# Crawler
CRAWLER_USER_AGENT="ApplyPilotAI/2.0 (+personal job monitoring)"
RESPECT_ROBOTS_TXT="true"
CRAWLER_MAX_LINKS_PER_SOURCE="40"
CRAWLER_FETCH_MODE="html"
