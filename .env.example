# App
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ApplyPilot AI"
APP_SESSION_SECRET="replace-this-with-a-long-random-secret"

# Default owner account created by `npm run db:seed`
APP_SINGLE_USER_EMAIL="owner@applypilot.local"
APP_SINGLE_USER_PASSWORD="ApplyPilot#2026"
APP_SINGLE_USER_NAME="ApplyPilot Owner"

# Database: for Docker Compose Postgres
DATABASE_URL="postgresql://applypilot:applypilot@localhost:5432/applypilot?schema=public"

# Redis: required for background worker
REDIS_URL="redis://localhost:6379"

# AI parser: optional. Without this key, regex + heuristic parser still works.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.5-mini"

# Crawler
CRAWLER_USER_AGENT="ApplyPilotAI/1.0 (+personal job monitoring)"
RESPECT_ROBOTS_TXT="true"
CRAWLER_MAX_LINKS_PER_SOURCE="30"
CRAWLER_FETCH_MODE="html"
